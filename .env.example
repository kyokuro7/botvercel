# Token Bot Telegram (dari @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Token API Vercel (dari https://vercel.com/account/tokens)
VERCEL_TOKEN=your_vercel_token_here

# Token API Netlify (dari https://app.netlify.com/user/applications/personal)
NETLIFY_TOKEN=your_netlify_token_here

# ID Telegram Owner (hanya pemilik yang bisa manage bot)
# Cara dapat ID kamu: chat @userinfobot di Telegram
OWNER_ID=your_telegram_user_id_here

# Channel Utama (wajib join sebelum bisa pakai bot)
# Bisa pakai @username atau numeric ID (contoh: -1001234567890)
# PENTING: Bot harus jadi admin di channel ini!
CHANNEL_ID=@your_channel_username
CHANNEL_URL=https://t.me/your_channel_username
